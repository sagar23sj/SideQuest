# Example environment for the Action Tracker backend.
# Copy to a secrets manager / local .env (never commit real secrets).

# Required
AT_DATABASE_DSN=postgres://user:password@localhost:5432/actiontracker?sslmode=disable
AT_JWT_SIGNING_SECRET=change-me-use-a-long-random-value

# Auth tokens (optional; defaults shown). Short-lived access + longer refresh.
AT_JWT_ISSUER=action-tracker
AT_ACCESS_TOKEN_TTL=15m
AT_REFRESH_TOKEN_TTL=720h

# Server (optional; defaults shown)
AT_LISTEN_ADDR=127.0.0.1:8080
AT_READ_HEADER_TIMEOUT=5s
AT_READ_TIMEOUT=15s
AT_WRITE_TIMEOUT=30s
AT_IDLE_TIMEOUT=120s
AT_SHUTDOWN_TIMEOUT=20s
AT_EXTERNAL_CALL_TIMEOUT=30s
AT_DB_MAX_CONNS=25

# Provider keys (server-side only; never returned to clients).
# Leave blank to run with proxy endpoints failing soft (503).
AT_LLM_PROVIDER_KEY=
AT_LLM_PROVIDER_BASE_URL=
AT_STT_PROVIDER_KEY=
AT_STT_PROVIDER_BASE_URL=
