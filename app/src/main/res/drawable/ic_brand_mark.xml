<?xml version="1.0" encoding="utf-8"?>
<!--
  SideQuest brand mark: a self-contained logo lockup that mirrors the adaptive
  launcher icon (rocket on a terracotta->coral gradient in a rounded square).
  Used consistently across the login/sign-up screen, the loading splash, and the
  profile hero so the app's identity matches its home-screen icon everywhere.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Rounded-square background with the brand terracotta->coral gradient. -->
    <path android:pathData="M28,4 L80,4 Q104,4 104,28 L104,80 Q104,104 80,104 L28,104 Q4,104 4,80 L4,28 Q4,4 28,4 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="14"
                android:startY="6"
                android:endX="94"
                android:endY="102">
                <item android:offset="0.0" android:color="#FFB36A4A" />
                <item android:offset="0.55" android:color="#FF9F4122" />
                <item android:offset="1.0" android:color="#FF7F2A0D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft decorative spark. -->
    <path
        android:pathData="M82,30m-18,0a18,18 0,1 1,36 0a18,18 0,1 1,-36 0z"
        android:fillColor="#FFFF8A65"
        android:fillAlpha="0.18" />

    <!-- Left fin -->
    <path
        android:fillColor="#FFFF8A65"
        android:pathData="M45,57 L34,72 Q33,73 35,72 L46,67 Z" />
    <!-- Right fin -->
    <path
        android:fillColor="#FFFF8A65"
        android:pathData="M63,57 L74,72 Q75,73 73,72 L62,67 Z" />

    <!-- Flame -->
    <path
        android:fillColor="#FFFFB59E"
        android:pathData="M47,68 L61,68 L57,82 Q54,87 51,82 Z" />
    <path
        android:fillColor="#FFFF8A65"
        android:pathData="M50,68 L58,68 L55.5,79 Q54,82 52.5,79 Z" />

    <!-- Rocket body -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M54,24 C62,32 66,44 66,57 L66,66 Q66,70 62,70 L46,70 Q42,70 42,66 L42,57 C42,44 46,32 54,24 Z" />

    <!-- Porthole -->
    <path
        android:fillColor="#FF9F4122"
        android:pathData="M54,46 m-7,0 a7,7 0,1 1,14 0 a7,7 0,1 1,-14 0z" />
    <path
        android:fillColor="#FFFFB59E"
        android:pathData="M54,46 m-3.5,0 a3.5,3.5 0,1 1,7 0 a3.5,3.5 0,1 1,-7 0z" />
</vector>
