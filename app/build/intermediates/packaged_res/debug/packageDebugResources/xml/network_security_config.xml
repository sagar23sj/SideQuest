<?xml version="1.0" encoding="utf-8"?>
<!--
    DEBUG-ONLY network security config.

    Allows cleartext (HTTP) traffic to a local development backend so the
    emulator OR a physical device can reach the Go server running on the host
    machine — whether that's http://10.0.2.2:8080 (emulator), http://localhost
    (adb reverse tcp:8080 tcp:8080), or the host's LAN IP (e.g.
    http://192.168.1.x:8080 when the phone is on the same Wi-Fi).

    A base-config with cleartext permitted keeps physical-device testing
    friction-free without hardcoding an IP that changes per network. This file
    lives in src/debug, so it is NOT part of release builds — release traffic
    stays HTTPS-only under Android's secure defaults.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
