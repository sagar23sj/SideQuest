<?xml version="1.0" encoding="utf-8"?>
<!--
  SideQuest adaptive-icon background: a warm terracotta-to-coral diagonal
  gradient (the brand primary #9F4122 into the coral primary-container #FF8A65)
  with a couple of soft, low-alpha "spark" circles for depth.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="14"
                android:startY="6"
                android:endX="94"
                android:endY="102">
                <item android:offset="0.0" android:color="#FFB36A4A" />
                <item android:offset="0.55" android:color="#FF9F4122" />
                <item android:offset="1.0" android:color="#FF7F2A0D" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Soft decorative sparks. -->
    <path
        android:pathData="M82,30m-20,0a20,20 0,1 1,40 0a20,20 0,1 1,-40 0z"
        android:fillColor="#FFFF8A65"
        android:fillAlpha="0.18" />
    <path
        android:pathData="M26,86m-16,0a16,16 0,1 1,32 0a16,16 0,1 1,-32 0z"
        android:fillColor="#FFFFFFFF"
        android:fillAlpha="0.08" />
</vector>
